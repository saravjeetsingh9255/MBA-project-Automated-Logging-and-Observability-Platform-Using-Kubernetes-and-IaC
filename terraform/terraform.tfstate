            "metadata": {
              "app_version": "5.0.6",
              "chart": "fluent-bit",
              "first_deployed": 1780596010,
              "last_deployed": 1780598414,
              "name": "fluent-bit",
              "namespace": "logging",
              "notes": "Get Fluent Bit build information by running these commands:\n\nexport POD_NAME=$(kubectl get pods --namespace logging -l \"app.kubernetes.io/name=fluent-bit,app.kubernetes.io/instance=fluent-bit\" -o jsonpath=\"{.items[0].metadata.name}\")\nkubectl --namespace logging port-forward $POD_NAME 2020:2020\ncurl http://127.0.0.1:2020 \n\n",
              "revision": 2,
              "values": "{\"config\":{\"filters\":\"[FILTER]\\r\\n    Name                kubernetes\\r\\n    Match               kube.*\\r\\n    Merge_Log           On\\r\\n    Keep_Log            Off\\r\\n    K8S-Logging.Parser  On\\r\\n    K8S-Logging.Exclude Off\\r\\n\",\"inputs\":\"[INPUT]\\r\\n    Name              tail\\r\\n    Path              /var/log/containers/*.log\\r\\n    Parser            cri\\r\\n    Tag               kube.*\\r\\n    Refresh_Interval  5\\r\\n    Mem_Buf_Limit     5MB\\r\\n    Skip_Long_Lines   On\\r\\n\",\"outputs\":\"[OUTPUT]\\r\\n    Name                es\\r\\n    Match               kube.*\\r\\n    Host                perfmonitor-es-es-http.logging.svc.cluster.local\\r\\n    Port                9200\\r\\n    HTTP_User           elastic\\r\\n    HTTP_Passwd         CSaB09L5B86k9WLK7qwJ09G3\\r\\n    TLS                 On\\r\\n    TLS.Verify          Off\\r\\n    Logstash_Format     On\\r\\n    Logstash_Prefix     kubernetes\\r\\n    Suppress_Type_Name  On\\r\\n    Retry_Limit         False\\r\\n\",\"service\":\"[SERVICE]\\r\\n    Flush        1\\r\\n    Log_Level    info\\r\\n    Daemon       off\\r\\n    Parsers_File parsers.conf\\r\\n    HTTP_Server  On\\r\\n    HTTP_Listen  0.0.0.0\\r\\n    HTTP_Port    2020\\r\\n\"}}",
              "version": "0.57.6"
            },
            "name": "fluent-bit",
            "namespace": "logging",
            "pass_credentials": false,
            "postrender": null,
            "recreate_pods": false,
            "render_subchart_notes": true,
