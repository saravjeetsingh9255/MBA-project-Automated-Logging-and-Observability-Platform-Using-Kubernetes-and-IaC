            "upgrade_install": false,
            "values": [
              "\"config\":\n  \"filters\": \"[FILTER]\\r\\n    Name                kubernetes\\r\\n    Match               kube.*\\r\\n\n    \\   Merge_Log           On\\r\\n    Keep_Log            Off\\r\\n    K8S-Logging.Parser\n    \\ On\\r\\n    K8S-Logging.Exclude Off\\r\\n\"\n  \"inputs\": \"[INPUT]\\r\\n    Name              tail\\r\\n    Path              /var/log/containers/*.log\\r\\n\n    \\   Parser            cri\\r\\n    Tag               kube.*\\r\\n    Refresh_Interval\n    \\ 5\\r\\n    Mem_Buf_Limit     5MB\\r\\n    Skip_Long_Lines   On\\r\\n\"\n  \"outputs\": \"[OUTPUT]\\r\\n    Name                es\\r\\n    Match               kube.*\\r\\n\n    \\   Host                perfmonitor-es-es-http.logging.svc.cluster.local\\r\\n    Port\n    \\               9200\\r\\n    HTTP_User           elastic\\r\\n    HTTP_Passwd         CSaB09L5B86k9WLK7qwJ09G3\\r\\n\n    \\   TLS                 On\\r\\n    TLS.Verify          Off\\r\\n    Logstash_Format\n    \\    On\\r\\n    Logstash_Prefix     kubernetes\\r\\n    Suppress_Type_Name  On\\r\\n\n    \\   Retry_Limit         False\\r\\n\"\n  \"service\": \"[SERVICE]\\r\\n    Flush        1\\r\\n    Log_Level    info\\r\\n    Daemon\n    \\      off\\r\\n    Parsers_File parsers.conf\\r\\n    HTTP_Server  On\\r\\n    HTTP_Listen\n    \\ 0.0.0.0\\r\\n    HTTP_Port    2020\\r\\n\"\n"
            ],
